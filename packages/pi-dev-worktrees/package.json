{
  "name": "@lanquarden/pi-dev-worktrees",
  "version": "0.2.0",
  "description": "Pi extension for isolated branch workspaces — git worktrees via wtp and optional devcontainer targeting",
  "license": "MIT",
  "keywords": [
    "pi-package",
    "pi-extension",
    "git",
    "worktrees",
    "devcontainer"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/lanquarden/pi-dev-worktrees",
    "directory": "packages/pi-dev-worktrees"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "src/",
    "README.md"
  ],
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@blackbelt-technology/pi-dashboard-shared": "*",
    "vitest": "^2.1.9"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  }
}
